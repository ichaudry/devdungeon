{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],

    "module": "ESNext",
    "skipLibCheck": true,

    "moduleResolution": "Bundler",
    "resolveJsonModule": true,

    "isolatedModules": true,
    "noEmit": true,

    "jsx": "react-jsx",

    "strict": true,

    "baseUrl": ".",

    "paths": {
      "@/*": ["src/*"],
      "@game/*": ["src/game/*"],
      "@ui/*": ["src/ui/*"],
      "@systems/*": ["src/systems/*"],
      "@entities/*": ["src/entities/*"]
    }
  },
  "include": ["src"],
  "references": []
}